macro void fatal_app_exit(uint uAction, char* lpMessageText)
@if(!$feature(WIN32_UNICODE))
{
    fatal_app_exitA(uAction, lpMessageText);
}

macro void fatal_app_exit(uint uAction, ushort* lpMessageText)
@if($feature(WIN32_UNICODE))
{
    fatal_app_exitW(uAction, lpMessageText);
}

<*
 @param [in] lpSource
 @param [in] arguments
*>
macro uint format_message(FormatMessageOptions dwFlags, void* lpSource, uint dwMessageId, uint dwLanguageId, char* lpBuffer, uint nSize, ichar** arguments)
@if(!$feature(WIN32_UNICODE))
{
    return format_messageA(dwFlags, lpSource, dwMessageId, dwLanguageId, lpBuffer, nSize, arguments);
}

<*
 @param [in] lpSource
 @param [in] arguments
*>
macro uint format_message(FormatMessageOptions dwFlags, void* lpSource, uint dwMessageId, uint dwLanguageId, ushort* lpBuffer, uint nSize, ichar** arguments)
@if($feature(WIN32_UNICODE))
{
    return format_messageW(dwFlags, lpSource, dwMessageId, dwLanguageId, lpBuffer, nSize, arguments);
}

<*
 @param [&out] headerSum
 @param [&out] checkSum
*>
macro uint map_file_and_check_sum(char* filename, uint* headerSum, uint* checkSum)
@if(!$feature(WIN32_UNICODE))
{
    return map_file_and_check_sumA(filename, headerSum, checkSum);
}

<*
 @param [&out] headerSum
 @param [&out] checkSum
*>
macro uint map_file_and_check_sum(ushort* filename, uint* headerSum, uint* checkSum)
@if($feature(WIN32_UNICODE))
{
    return map_file_and_check_sumW(filename, headerSum, checkSum);
}

macro void output_debug_string(char* lpOutputString)
@if(!$feature(WIN32_UNICODE))
{
    output_debug_stringA(lpOutputString);
}

macro void output_debug_string(ushort* lpOutputString)
@if($feature(WIN32_UNICODE))
{
    output_debug_stringW(lpOutputString);
}

