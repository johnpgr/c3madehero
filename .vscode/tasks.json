{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C3 build debug",
      "type": "shell",
      "command": "c3c build c3madehero-debug && c3c build c3madehero_game-debug",
      "group": "build",
      "problemMatcher": {
        "owner": "c3",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^\\((.+):(\\d+):(\\d+)\\)\\s+(Error|Warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
    {
      "label": "C3 build release",
      "type": "shell",
      "command": "c3c build c3madehero-release && c3c build c3madehero_game-release",
