        "owner": "c3",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^\\((.+):(\\d+):(\\d+)\\)\\s+(Error|Warning):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    },
